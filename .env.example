# Copy to .env and fill in real values. .env is gitignored.

# === LLM provider — at minimum one of these is required ===
OPENAI_API_KEY=sk-your-openai-key-here
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# === LiteLLM proxy master key ===
# Anything; must match [llm].api_key in dev.toml.
LITELLM_MASTER_KEY=sk-dev-key

# === GitHub App credentials (when [vcs].provider = "github") ===
# Register at https://github.com/settings/apps. Required permissions:
# Contents:read, Pull requests:read+write, Checks:read+write, Metadata:read.
# Subscribe to: pull_request, pull_request_review_comment, push, check_run, reaction.
GITHUB_APP_ID=123456
GITHUB_INSTALLATION_ID=78901234
GITHUB_WEBHOOK_SECRET=changeme-to-something-strong

# Place your GitHub App private key (PEM) at docker/github-app-key.pem.
# It is mounted into the worker containers at /run/secrets/github-app-key.pem.

# === Bitbucket OAuth credentials (when [vcs].provider = "bitbucket") ===
# Create an OAuth consumer at:
#   https://bitbucket.org/<workspace>/workspace/settings/api
# Required scopes: Repositories:Read, Pull requests:Write, Webhooks.
# The same webhook secret variable (GITHUB_WEBHOOK_SECRET above) is
# reused for HMAC verification on Bitbucket deliveries.
BITBUCKET_CLIENT_ID=
BITBUCKET_CLIENT_SECRET=
# Workspace slug (the URL piece in https://bitbucket.org/<workspace>/).
BITBUCKET_WORKSPACE=

# === Admin UI ===
# Password for cmd/admin-ui at http://localhost:8090
ADMIN_PASSWORD=changeme-please
# 32+ bytes of entropy. Rotating this signs everyone out.
ADMIN_SESSION_SECRET=changeme-32-byte-random-string-here

# Optional GitHub OAuth for admin login. Leave CLIENT_ID empty to disable.
ADMIN_GITHUB_OAUTH_CLIENT_ID=
ADMIN_GITHUB_OAUTH_CLIENT_SECRET=
ADMIN_GITHUB_OAUTH_CALLBACK_URL=http://localhost:8090/oauth/github/callback

# === Issue-tracker plugins for review context (all optional) ===
# JIRA Cloud — leave JIRA_BASE_URL empty to disable.
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=

# Linear — leave LINEAR_API_KEY empty to disable.
LINEAR_API_KEY=
